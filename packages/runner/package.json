{
  "name": "@repoarena/runner",
  "version": "0.1.0",
  "description": "Benchmark orchestrator for RepoArena",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@repoarena/adapters": "workspace:*",
    "@repoarena/core": "workspace:*",
    "@repoarena/judges": "workspace:*",
    "@repoarena/report": "workspace:*",
    "@repoarena/taskpacks": "workspace:*",
    "@repoarena/trace": "workspace:*",
    "picomatch": "^4.0.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.2"
  }
}
